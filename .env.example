# ─── 基础配置 ──────────────────────────────────────
# 从浏览器 F12 → Network → 任意请求 → Headers → Cookie 复制
DOUYIN_COOKIE=

# ─── 自动回复 ──────────────────────────────────────
# 监控好友白名单（JSON 数组，空数组=全部回复）
MONITOR_WATCH_FRIENDS=[]

# 默认回复内容
MONITOR_DEFAULT_REPLY=收到，稍后回复你~

# 自动回复图片路径（本地文件，优先于文本，留空=发文本）
# Docker: /app/images/xxx.jpg  本地: /opt/douyin-auto-reply/images/xxx.jpg
MONITOR_REPLY_IMAGE_PATH=

# 超过几点未回复则补发（0-23）
MONITOR_MAX_WAIT_HOURS=23

# ─── 主动发信 ──────────────────────────────────────
# 当天无任何私信时，主动发一条的目标会话 ID
# 从浏览器 F12 抓包获取 conversation_id，留空=不启用
MONITOR_PROACTIVE_TARGET_ID=

# 主动发信内容
MONITOR_PROACTIVE_TEXT=今天过得怎么样？

# 主动发信图片路径（本地文件，优先于文本，留空=发文本）
# Docker: /app/images/xxx.jpg  本地: /opt/douyin-auto-reply/images/xxx.jpg
MONITOR_PROACTIVE_IMAGE_PATH=

# 在几点之前无消息则发送（0-23，默认 20 点）
MONITOR_PROACTIVE_HOUR=20

# ─── 磁盘清理 ──────────────────────────────────────
# 日志文件保留天数（默认 7 天）
MONITOR_CLEANUP_KEEP_DAYS=7
